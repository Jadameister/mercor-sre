KRAKEN_WS_URL=wss://ws.kraken.com/v2
# Use localhost:19092 when the Python app runs on your machine against this repo's Docker Compose stack.
# Use kafka:9092 when the Python app runs inside Docker Compose.
# Use localhost:9092 only if you have your own local Kafka outside this compose stack.
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TOPIC=kraken-market-data
KRAKEN_CHANNEL=ticker
KRAKEN_SYMBOLS=BTC/USD,ETH/USD,XRP/USD
KRAKEN_BOOK_DEPTH=10
LOG_LEVEL=DEBUG

# Optional InfluxDB 2 latency sink
# Enable this when you want the local Python app to write latency points into the Docker Compose InfluxDB service.
INFLUXDB_ENABLED=true
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=marketdata-token
INFLUXDB_ORG=test-org
INFLUXDB_BUCKET=marketdata

# Optional SASL config
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=your-username
# KAFKA_SASL_PASSWORD=your-password
